{
  "name": "frontend_odoo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "postinstall": "node -e \"const fs=require('fs'),p=require('path');const candidates=[p.join('node_modules','react-pdf','node_modules','pdfjs-dist','build','pdf.worker.min.mjs'),p.join('node_modules','pdfjs-dist','build','pdf.worker.min.mjs')];try{fs.mkdirSync('public',{recursive:true});const src=candidates.find(c=>fs.existsSync(c));if(!src)throw new Error('worker não encontrado');fs.copyFileSync(src,p.join('public','pdf.worker.min.mjs'));console.log('pdfjs worker copiado de',src)}catch(e){console.error('postinstall pdfjs worker:',e.message)}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.99.0",
    "@tanstack/react-query-devtools": "^5.99.0",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "geist": "^1.7.0",
    "lucide-react": "^0.414.0",
    "next": "14.2.35",
    "next-themes": "^0.3.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.72.1",
    "react-hot-toast": "^2.6.0",
    "react-intersection-observer": "^9.16.0",
    "react-pdf": "^9.2.1",
    "tailwind-merge": "^2.6.1",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/ui": "^4.1.4",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
